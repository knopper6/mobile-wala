{
  "name": "mobilewala-auction-backend",
  "version": "1.0.0",
  "description": "Backend API for MobileWala refurbished mobile phone wholesale auctions.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:schema": "psql \"$DATABASE_URL\" -f database/schema.sql",
    "db:seed": "psql \"$DATABASE_URL\" -f database/seed.sql",
    "db:reset": "npm run db:schema && npm run db:seed",
    "hash-password": "node scripts/hash-password.js"
  },
  "keywords": [
    "auction",
    "express",
    "postgresql",
    "refurbished-mobile"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  },
  "engines": {
    "node": ">=18"
  }
}
